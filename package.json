{
  "name": "scalable-blockchain-voting",
  "version": "0.1.0",
  "private": true,
  "description": "Zero-cost testnet demonstration of a scalable privacy-preserving voting pipeline.",
  "license": "MIT",
  "type": "module",
  "scripts": {
    "clean": "hardhat clean",
    "compile": "hardhat compile",
    "test:crypto": "node --test --import tsx test/CryptoBatching.ts",
    "test": "hardhat test",
    "typecheck": "tsc --noEmit",
    "deploy:local": "hardhat ignition deploy ignition/modules/VotingSystem.ts",
    "deploy:amoy": "hardhat ignition deploy ignition/modules/VotingSystem.ts --network amoy"
  },
  "devDependencies": {
    "@nomicfoundation/hardhat-ignition": "^3.1.7",
    "@nomicfoundation/hardhat-toolbox-viem": "^5.0.7",
    "@openzeppelin/contracts": "^5.6.1",
    "@types/node": "^22.20.0",
    "hardhat": "^3.9.0",
    "tsx": "^4.22.4",
    "typescript": "~6.0.3",
    "viem": "^2.53.1"
  },
  "engines": {
    "node": ">=22.13.0"
  }
}
